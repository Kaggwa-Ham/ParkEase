doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Log In
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/style.css')
body.dashboard-page
  div.nav-set
    nav.navbar
      .logo
        | ParkEase
      ul.nav-links
        li
          a(href='/') Home
          if user 
            if user.role === "Admin"
              li
                a(href="/admin") Dashboard
              li 
                a(href='/auth/signup') Register User 
              li 
                a(href="/usersList") Manage Users
            if user.role === "Manager"
              li 
                a(href="/manager") Dashboard
              li 
                a(href="/batteryServices") Battery Services
              li 
                a(href="/tyreServices") Tyre Clinic
            if user.role === "Attendant"
              li
                a(href="/attendant") Dashboard
              li 
                a(href="/registerVehicle") Register Vehicle
              li 
                a(href="/signoutconfirm") Vehicle Signout
      .nav-right
        if user 
          div.profile
            i.fa-solid.fa-user-circle.me-1 
            | Hi #{user.firstName}: #{user.role}
          div
            ul.nav-links
              li 
                a(href="/auth/logout") Log Out
        else
          ul.nav-links
            li
              a(href="/auth/login") Log in
    block content
      br 
    footer
      .container.text-center 
      p.mb-0 &copy;  2026 Kaggwa Ham @ParkEase. All Rights Reserved