extends layout
block content 
    .dashboard-top
    .stats
        .card
            h3 Available Batteries
            p #{batteries.length}
    table
        thead
            tr
                th Battery image
                th Battery Type
                th Battery Size
                th  Hire
                th Sale
        tbody
            if batteries.length 
                each battery in batteries 
                    tr
                        td 
                            img(src = "/" + battery.batteryImage alt = "Battery image" width = "100px" height="90px")
                        td #{battery.batteryType}
                        td #{battery.batterySize}
                        td UGX #{battery.hire.toLocaleString()}
                        td UGX #{battery.sale.toLocaleString()}
    script(src='javaScript/dashboard.js')
