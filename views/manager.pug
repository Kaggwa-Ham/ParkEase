extends layout
block content 
    .dashboard-top
        .search-wrapper
        input.dashboard-search(type='text' placeholder='Search vehicle by number plate...')
    .stats
        .card
            h3 Available Batteries
            p #{batteries.length}
        .card
            h3 Total Revenue
            p #{batteriesTotal}
        .card
            h3 Available Slots
            p 16
        .card
            h3 Available Tyres
            p 3
    table
        thead
            tr
                th Battery image
                th batteryType
                th batterySize
        tbody
            if batteries.length 
                each battery in batteries 
                    tr
                        td 
                            img(src = "/" + battery.batteryImage alt = "Battery image" width = "100px" height="90px")
                        td #{battery.batteryType}
                        td #{battery.batterySize}
    script(src='javaScript/dashboard.js')
