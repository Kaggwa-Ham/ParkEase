extends layout
block content 
  h1 Attendant Dashboard
  .dashboard-container
    .stats
      .card
        h3 Parked Vehicles
        p #{vehicles.length}
      .card
        h3 Total Revenue
        p #{parkingRevenue}
      .card
        h3 Available Slots
        p= 50 - vehicles.length
  form.dateFilter(action="/attendant" method="GET")   
    div
        label(for="dateFilter") Filter by Day:
        input#dateFilter(type="date" name="date" value=selectedDate)
    div
        button.btn-submit(type="submit") 
            i.fa-solid.fa-filter.me-1
            | Filter
  table
      thead
          tr
              th Image
              th Driver Name
              th Phone Number
              th Vehicle Type
              th Number Plate
              th Vehicle Model
              th Vehicle Color
              th Arrival Time
              th Receipt Number
              th Action
      tbody
          if vehicles.length 
              each vehicle in vehicles 
                  tr
                      td
                          img(src = "/" + vehicle.vehicleImage alt = "Vehicle image" width = "180px" height = "170px")
                      td #{vehicle.driverName}
                      td #{vehicle.phoneNumber}
                      td #{vehicle.vehicleType}
                      td #{vehicle.numberPlate}
                      td #{vehicle.vehicleModel}
                      td #{vehicle.vehicleColor}
                      td= vehicle.arrivalTime.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})  
                      td #{vehicle.receiptNumber} 
                      td 
                        button.btn.btn-sm.btn-outline-warning.text-dark(onclick=`navigator.clipboard.writeText("${vehicle.receiptNumber}"); alert("Receipt ${vehicle.receiptNumber} copied");`) 
                          i.fa-solid.fa-copy.me-1 
                          | Copy      
          else 
              tr 
                  td No vehicles found
         
  script(src='javaScript/dashboard.js')
  
