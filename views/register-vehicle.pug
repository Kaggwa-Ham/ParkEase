extends layout
block content 
  form(method='post' action='/registerVehicle' enctype='multipart/form-data')
    div.form-card
      div
        h3.title Vehicle Registration
      div.driverDetails
        h5 Driver Details
        p.underline
        div
          label(for='driverName') Driver Name
          input#driverName(type='text' name='driverName')
        div
          label(for='phoneNumber') Phone Number
          input#phoneNumber.form-control(type=' tel'  name='phoneNumber')
      div.vehicleDetails
        h5 Vehicle Details
        p.underline
        div
          label(for='vehicleType') Vehicle Type
          select#vehicleType.form-select(name='vehicleType')
            option(value='' selected='' disabled='') Select type...
            option(value='Truck') Truck
            option(value='Personal Car') Personal Car
            option(value='Taxi') Taxi
            option(value='Coaster') Coaster
            option(value='Boda-boda') Boda-boda
        div
          label(for='numberPlate') Number Plate
          input#numberPlate.form-control(type='text' name='numberPlate')
        div
          label(for='vehicleModel') Vehicle Model
          input#vehicleModel.form-control(type='text' name='vehicleModel')
          label.form-label(for='vehicleImage') Vehicle Image
          input#vehicleImage.form-control(type='file' name='vehicleImage')
        div
          label(for='vehicleColor') Vehicle Color
          input#vehicleColor.form-control(type='text'  name='vehicleColor')
        div
          label(for='ninNumber') NIN Number
          input#ninNumber(type='text' name='ninNumber')
      button.btn-submit(type='submit')
        | Register Vehicle
  script(src="/js/vehicleRegister.js") 