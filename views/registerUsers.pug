extends layout
block content
    div.form-card
        form#userForm(method='post' action='/auth/signup')
            div.userDetails
                h2 Create an Account
                p.underline
                div 
                    label(for='firstName') First Name
                    input#firstName(type='text' placeholder='James' name='firstName')
                div
                    label(for='lastName') Last Name
                    input#secondName(type='text' placeholder='Kisakye' name='lastName')
                div
                    label(for='email') Email Address
                    input#email(type='text' placeholder='name@gmail.com' name='email')
                div
                    label(for='phone') Phone Number
                    input#phoneNumber(type='text' placeholder='+256 700 000000' name='phoneNumber')
                div
                    label(for='ninNumber') NIN Number
                    input#ninNumber(type='text' name='ninNumber')
                div
                    label(for='role') Role
                    select(name="role")
                        option(value="") Select role 
                        option(value="Admin") Admin 
                        option(value="Manager") Manager 
                        option(value="Attendant") Attendant   
                div 
                    label(for='password') Password
                    input#password(type='password' placeholder='••••••••' name='password')
                div#resultMessage
            button.btn-submit(type='submit') Register User
            script(src='/js/userRegisterValidation.js')
