extends layout 
block content      
    table
        thead
            tr
                th First Name
                th Last Name
                th Email
                th PhoneNumber
                th Role
        tbody
            if users.length 
                each user in users 
                    tr
                        td #{user.firstName}
                        td #{user.lastName}
                        td #{user.email}
                        td #{user.phoneNumber}
                        td #{user.role}
            else 
                tr 
                    td No users found            
                