extends layout
block content 
  div.receipt-section
    div.receiptIntro
      h2 Park Ease
      p Intergrated Parking System
      h5 Official receipt
      div.title
        p= record.receiptNumber

    //- Transaction details
    div
      div.highlights
        p Date: 
        p= new Date(record.signoutTime).toLocaleDateString()
      div.highlights
        p Time Out: 
        p= new Date(record.signoutTime).toLocaleTimeString([], {hour: "2-digit", minute: "2-digit"})
      div.highlights
        p Vehicle Numberplate:
        p= record.vehicleId.numberPlate
      div.highlights
        p Vehicle Type:
        p= record.vehicleId.vehicleType
      div.highlights
        p Receiver Name:  
        p= record.receiverName
    div.highlights
      p Total Paid
      p UGX #{record.amountPaid.toLocaleString()}
    div.title
      p.small.mb-0 Thank you for using ParkEase!
      p.small Drive Safely

    //- Print Receipt
    div
      button.btn-submit(onclick="window.print()")
          i.fa-solid.fa-print.me-2
          | Print Receipt 


  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
