doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Register User
  link(rel='stylesheet' href='css/styles.css')
.nav-set
  nav.navbar
    .logo
      | ParkEase
    ul.nav-links
      li
        a(href='register.html') Register Car
      li
        a.admin-link(href='reports.html') Admin
      li
        a(href='batterySection.html') Battery Section
      li
        a(href='tyreClinic.html') Tyre Clinic
      li
        a(href='dashboard.html') Dashboard
      li
        a(href='signOut.html') Check Out
    .nav-right
      span.user-role Admin
      a.logout-btn(href='index.html') Logout
  h1 Parkease Attendant Registration
  .dashboard
    form#attendantForm
      input#name(type='text' placeholder='Full Name')
      input#passkey(type='password' placeholder='Passkey')
      input#dob(type='date')
      input#nin(type='text' placeholder='NIN Number')
      input#phone(type='text' placeholder='Phone Number')
      input#station(type='text' placeholder='Parking Station')
      select#shift
        option(value='') Select Shift
        option Day
        option Night
      button.btn-submit(type='submit') Register Attendant
    div
      h2 Registered Attendants
      table#attendantsTable
        thead
          tr
            th ID
            th Name
            th NIN
            th Station
            th Shift
        tbody
script(src='javaScript/registerUser.js')
